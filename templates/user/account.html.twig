{% extends 'base.html.twig' %}

{% block return_link %}
    {{ path('app_mobile_othermenu') }}
{% endblock %}

{% block return_text %}
    Autre
{% endblock %}

{% block title %}Mon compte{% endblock title %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <em class="fa-solid fa-user-gear me-2"></em>
            Mon compte
        </h1>
    </div>

    <div class="row">
        <!-- Informations personnelles -->
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <em class="fa-solid fa-id-card me-2"></em>
                        Informations personnelles
                    </h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <label class="text-muted small mb-1">Identifiant</label>
                        <div class="d-flex align-items-center">
                            <em class="fa-solid fa-envelope text-primary me-2"></em>
                            <strong>{{ user.email }}</strong>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small mb-1">Nom complet</label>
                        <div class="d-flex align-items-center">
                            <em class="fa-solid fa-user text-primary me-2"></em>
                            <strong>{{ user.firstname }} {{ user.lastname }}</strong>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small mb-1">Numéro de téléphone</label>
                        <div class="d-flex align-items-center">
                            <em class="fa-solid fa-phone text-primary me-2"></em>
                            {% if user.phoneNumber %}
                                <a href="tel:{{ user.phoneNumber }}">{{ user.phoneNumber }}</a>
                            {% else %}
                                <em class="text-muted">Non renseigné</em>
                            {% endif %}
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small mb-1">Mot de passe</label>
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <em class="fa-solid fa-lock text-primary me-2"></em>
                                <span>••••••••••••</span>
                            </div>
                            <a href="{{ path('app_forgot_password_request') }}" class="btn btn-sm btn-outline-primary">
                                <em class="fa-solid fa-key me-1"></em>
                                Changer
                            </a>
                        </div>
                    </div>

                    <div class="mb-0">
                        <label class="text-muted small mb-2">Compte Discord</label>
                        <div>
                            {% if user.discordId %}
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <em class="fa-brands fa-discord text-primary fa-lg me-2"></em>
                                        <span class="badge bg-success">Connecté</span>
                                    </div>
                                    <a href="{{ path('connect_discord_logout') }}" class="btn btn-sm btn-outline-danger">
                                        <em class="fa-solid fa-right-from-bracket me-1"></em>
                                        Déconnecter
                                    </a>
                                </div>
                            {% else %}
                                <a href="{{ path('connect_discord_start') }}" class="btn btn-discord w-100">
                                    <em class="fa-brands fa-discord me-2"></em>
                                    Se connecter avec Discord
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Licenciés gérés -->
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <em class="fa-solid fa-users me-2"></em>
                        Mes licenciés
                        <span class="badge bg-white text-success ms-2">{{ user.licensees|length }}</span>
                    </h4>
                </div>
                <div class="card-body">
                    {% if user.licensees is empty %}
                        <div class="text-center text-muted py-5">
                            <em class="fa-solid fa-user-slash fa-3x mb-3"></em>
                            <p class="mb-0">Aucun licencié associé</p>
                        </div>
                    {% else %}
                        <div class="list-group list-group-flush">
                            {% for licensee in user.licensees %}
                                <a href="{{ path('app_licensee_profile', {'id': licensee.id}) }}" 
                                   class="list-group-item list-group-item-action border-0 px-0">
                                    <div class="d-flex align-items-center">
                                        <img src="{{ licensee.profilePicture ? licensee.profilePicture|temporary_url : asset('build/profilePictureVertical.svg') }}"
                                             class="rounded-circle me-3" 
                                             style="width: 60px; height: 60px; object-fit: cover;" 
                                             alt="{{ licensee_display_name(licensee) }}">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center mb-1">
                                                <h5 class="mb-0 me-2">{{ licensee_display_name(licensee) }}</h5>
                                                {% if licensee == licenseeHelper.licenseeFromSession %}
                                                    <span class="badge bg-primary">
                                                        <em class="fa-solid fa-check me-1"></em>
                                                        Sélectionné
                                                    </span>
                                                {% endif %}
                                            </div>
                                            <small class="text-muted">
                                                <em class="fa-solid fa-building me-1"></em>
                                                {{ licensee.licenseForSeason(seasonHelper.selectedSeason).club.name ?? "Aucune licence cette saison" }}
                                            </small>
                                        </div>
                                        <em class="fa-solid fa-chevron-right text-muted"></em>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Abonnement au calendrier -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <em class="fa-solid fa-calendar me-2"></em>
                        Abonnement au calendrier
                    </h4>
                    <a href="{{ path('app_help_calendar') }}" class="btn btn-sm btn-outline-light">
                        <em class="fa-solid fa-circle-question me-1"></em>
                        Comment s'abonner ?
                    </a>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        Chaque licencié dispose de son propre lien d'abonnement. Abonnez-vous pour voir
                        les inscriptions directement dans Google Calendar, Apple Calendar ou Outlook.
                    </p>

                    {% if user.licensees is empty %}
                        <p class="text-muted">Aucun licencié associé à ce compte.</p>
                    {% else %}
                        {% for licensee in user.licensees %}
                            <div class="border rounded p-3 {% if not loop.last %}mb-3{% endif %}">
                                <div class="d-flex align-items-center mb-3">
                                    <img src="{{ licensee.profilePicture ? licensee.profilePicture|temporary_url : asset('build/profilePictureVertical.svg') }}"
                                         class="rounded-circle me-2"
                                         style="width: 36px; height: 36px; object-fit: cover;"
                                         alt="{{ licensee_display_name(licensee) }}">
                                    <strong>{{ licensee_display_name(licensee) }}</strong>
                                </div>

                                {% if licensee.calendarToken %}
                                    {% set feed_url = url('app_calendar_feed', {token: licensee.calendarToken}) %}
                                    <div class="mb-2">
                                        <div class="input-group input-group-sm" data-controller="clipboard-copy">
                                            <input type="text"
                                                   class="form-control font-monospace"
                                                   id="calendar-feed-url-{{ licensee.id }}"
                                                   data-clipboard-copy-target="source"
                                                   value="{{ feed_url }}"
                                                   readonly>
                                            <button class="btn btn-outline-secondary"
                                                    type="button"
                                                    data-action="clipboard-copy#copy"
                                                    title="Copier le lien">
                                                <em class="fa-solid fa-copy"></em>
                                                <span data-clipboard-copy-target="label">Copier</span>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <form method="post" action="{{ path('app_calendar_generate_token', {id: licensee.id}) }}">
                                            <button type="submit" class="btn btn-warning btn-sm"
                                                    data-controller="confirm-action"
                                                    data-action="click->confirm-action#confirm"
                                                    data-confirm-action-message-value="Êtes-vous sûr ? L'ancien lien cessera de fonctionner."
                                                    title="Générer un nouveau lien (l'ancien ne fonctionnera plus)">
                                                <em class="fa-solid fa-rotate-right me-1"></em>
                                                Regénérer
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('app_calendar_revoke_token', {id: licensee.id}) }}">
                                            <button type="submit" class="btn btn-danger btn-sm"
                                                    data-controller="confirm-action"
                                                    data-action="click->confirm-action#confirm"
                                                    data-confirm-action-message-value="Êtes-vous sûr ? Le lien cessera de fonctionner immédiatement."
                                                    title="Révoquer le lien d'abonnement">
                                                <em class="fa-solid fa-xmark me-1"></em>
                                                Révoquer
                                            </button>
                                        </form>
                                    </div>
                                {% else %}
                                    <form method="post" action="{{ path('app_calendar_generate_token', {id: licensee.id}) }}">
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            <em class="fa-solid fa-calendar-plus me-1"></em>
                                            Générer un lien d'abonnement
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Aide et contact -->
    <div class="row">
        <div class="col-12">
            <div class="card border-info">
                <div class="card-body">
                    <div class="d-flex align-items-start">
                        <em class="fa-solid fa-circle-info text-info fa-2x me-3"></em>
                        <div>
                            <h5 class="card-title mb-2">Besoin d'aide ?</h5>
                            <p class="card-text mb-0">
                                {% if licenseHelper.currentLicenseeCurrentLicense %}
                                    Pour toute question ou modification, contactez votre club à 
                                    <a href="mailto:{{ licenseHelper.currentLicenseeCurrentLicense.club.contactEmail }}" class="fw-bold">
                                        {{ licenseHelper.currentLicenseeCurrentLicense.club.contactEmail }}
                                    </a>
                                {% else %}
                                    Vous n'avez actuellement aucune licence active. Pour toute question, contactez le support à 
                                    <a href="mailto:arnaud@flyingpingu.com" class="fw-bold">arnaud@flyingpingu.com</a>
                                {% endif %}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock body %}