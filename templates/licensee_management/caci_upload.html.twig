{% extends 'base.html.twig' %}

{% block title %}CACI — {{ licensee.fullname }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_licensee_caci') }}">Suivi CACI</a></li>
                    <li class="breadcrumb-item active">{{ licensee.fullname }}</li>
                </ol>
            </nav>

            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <em class="fa-solid fa-file-medical me-2"></em>
                        CACI — {{ licensee.fullname }}
                        <span class="badge bg-light text-dark ms-2 fw-normal">Saison {{ season }}</span>
                    </h5>
                </div>
                <div class="card-body">
                    {% if not isNew %}
                        <div class="alert alert-info">
                            <em class="fa-solid fa-circle-info me-2"></em>
                            Un certificat existe déjà pour ce licencié. Vous pouvez remplacer le fichier et/ou mettre à jour la date.
                        </div>
                    {% endif %}

                    {{ form_start(form, {
                        attr: { enctype: 'multipart/form-data', novalidate: 'novalidate' }
                    }) }}

                    <div class="mb-3">
                        {{ form_row(form.uploadedFile) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.documentDate) }}
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a href="{{ path('app_licensee_caci') }}" class="btn btn-outline-secondary">
                            <em class="fa-solid fa-xmark me-1"></em>
                            Annuler
                        </a>
                        <button type="submit" class="btn btn-info text-white">
                            <em class="fa-solid fa-floppy-disk me-1"></em>
                            Enregistrer
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
