{% extends 'base.html.twig' %}

{% block title %}Déplacer le licencié — Étape 1 : Destination{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_licensee_index') }}">Licenciés</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_licensee_profile', {id: licensee.id}) }}">{{ licensee.fullname }}</a></li>
                    <li class="breadcrumb-item active">Déplacer vers un autre compte</li>
                </ol>
            </nav>

            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0">
                        <em class="fa-solid fa-right-left me-2"></em>
                        Déplacer le licencié vers un autre compte
                    </h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <em class="fa-solid fa-circle-info me-2"></em>
                        <strong>Licencié :</strong> {{ licensee.fullname }}<br>
                        <strong>Compte actuel :</strong>
                        {% if licensee.user %}
                            {{ licensee.user.firstname }} {{ licensee.user.lastname }} ({{ licensee.user.email }})
                        {% else %}
                            <em class="text-muted">Aucun compte</em>
                        {% endif %}
                    </div>
                    {% form_theme form 'bootstrap_5_layout.html.twig' %}                    {{ form_start(form, {attr: {'data-controller': 'user-choice', 'data-action': 'change->user-choice#update'}}) }}
                        <div class="mb-4">
                            {{ form_row(form.user_choice) }}
                        </div>

                        <div id="new_user_field" data-user-choice-target="newField">
                            <div class="mb-3">
                                {{ form_row(form.email) }}
                                <small class="form-text text-muted">
                                    <em class="fa-solid fa-envelope me-1"></em>
                                    Un lien de création de mot de passe sera envoyé à cette adresse.
                                </small>
                            </div>
                        </div>

                        <div id="existing_user_field" class="d-none" data-user-choice-target="existingField">
                            <div class="mb-3">
                                {{ form_row(form.existing_user) }}
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a href="{{ path('app_licensee_profile', {id: licensee.id}) }}" class="btn btn-secondary">
                                <em class="fa-solid fa-xmark me-2"></em>
                                Annuler
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <em class="fa-solid fa-arrow-right me-2"></em>
                                Suivant — Confirmer
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
